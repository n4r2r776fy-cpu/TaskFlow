<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\TaskFlow.Api.dll" stdoutLogEnabled="true" stdoutLogFile=".\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
